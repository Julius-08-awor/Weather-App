@page "/"
@using System.Net.Http.Json
@using WeatherApp.Models
@inject HttpClient Http
@inject IJSRuntime JS

<PageTitle>Weather Response System</PageTitle>

<style>
    * { box-sizing: border-box; margin: 0; padding: 0; }
    .container { min-height:100vh; font-family:Segoe UI,sans-serif; padding:24px 16px; transition:background 1s; }
    .inner { max-width:580px; margin:0 auto; }
    .search-bar { display:flex; gap:8px; margin-bottom:12px; }
    .search-input { flex:1; padding:14px 18px; border-radius:12px; border:none; font-size:1rem; background:rgba(255,255,255,0.2); color:white; outline:none; width:100%; }
    .search-input::placeholder { color:#ddd; }
    .btn-primary { padding:14px 18px; background:#00b4d8; color:white; border:none; border-radius:12px; font-size:1rem; cursor:pointer; font-weight:bold; white-space:nowrap; }
    .btn-secondary { padding:10px 16px; background:rgba(255,255,255,0.15); color:white; border:1px solid rgba(255,255,255,0.3); border-radius:12px; font-size:0.9rem; cursor:pointer; font-weight:bold; }
    .card { background:rgba(255,255,255,0.1); border-radius:24px; padding:28px; color:white; border:1px solid rgba(255,255,255,0.2); margin-bottom:16px; }
    .stats-grid { display:grid; grid-template-columns:repeat(3,1fr); gap:10px; margin-top:16px; }
    .stat-box { background:rgba(255,255,255,0.1); border-radius:12px; padding:12px 8px; text-align:center; }
    .forecast-grid { display:grid; grid-template-columns:repeat(5,1fr); gap:8px; }
    .forecast-box { background:rgba(255,255,255,0.1); border-radius:16px; padding:10px 6px; color:white; text-align:center; }
    .suggestion-box { background:#1e1e2e; border-radius:12px; overflow:hidden; margin-bottom:12px; }
    .suggestion-item { padding:10px 16px; color:white; cursor:pointer; border-bottom:1px solid rgba(255,255,255,0.1); font-size:0.95rem; }
    .chip { padding:6px 14px; background:rgba(255,255,255,0.15); color:white; border:1px solid rgba(255,255,255,0.3); border-radius:20px; cursor:pointer; font-size:0.85rem; }
    .alert-box { background:rgba(255,77,77,0.2); border:1px solid #ff4d4d; border-radius:12px; padding:14px 16px; color:#ff6b6b; margin-bottom:16px; }
    @@media (max-width:480px) {
        .stats-grid { grid-template-columns:repeat(2,1fr); }
        .forecast-grid { grid-template-columns:repeat(3,1fr); }
        .btn-primary { padding:14px 12px; font-size:0.9rem; }
    }
    @@keyframes spin { 0% { transform:rotate(0deg); } 100% { transform:rotate(360deg); } }
</style>

<div class="container" style="background:@GetBackground()">
    <div class="inner">

        <h1 style="text-align:center; color:white; font-size:2rem; margin-bottom:4px;">🌍 Weather Respponse System</h1>
        <p style="text-align:center; color:#ddd; margin-bottom:20px; font-size:0.95rem;">Real-time weather data & smart alerts for any city</p>

        <!-- Search Bar -->
        <div class="search-bar">
            <input class="search-input"
                   @bind="city"
                   @oninput="OnSearchInput"
                   placeholder="Enter city name..." />
            <button class="btn-primary" @onclick="GetWeather">Search</button>
            <button class="btn-secondary" @onclick="GetLocationWeather" title="Use my location">📍</button>
        </div>

        <!-- Search Suggestions -->
        @if (suggestions.Count > 0)
        {
            <div class="suggestion-box">
                @foreach (var s in suggestions)
                {
                    <div class="suggestion-item" @onclick="() => SelectSuggestion(s)">📍 @s</div>
                }
            </div>
        }

        <!-- Recent Searches -->
        @if (recentCities.Count > 0)
        {
            <div style="margin-bottom:16px;">
                <p style="color:#ddd; font-size:0.8rem; margin-bottom:8px;">Recent:</p>
                <div style="display:flex; flex-wrap:wrap; gap:8px;">
                    @foreach (var c in recentCities)
                    {
                        <button class="chip" @onclick="() => SearchCity(c)">@c</button>
                    }
                </div>
            </div>
        }

        <!-- Favorites -->
        @if (favoriteCities.Count > 0)
        {
            <div style="margin-bottom:16px;">
                <p style="color:#ffd700; font-size:0.8rem; margin-bottom:8px;">⭐ Favorites:</p>
                <div style="display:flex; flex-wrap:wrap; gap:8px;">
                    @foreach (var c in favoriteCities)
                    {
                        <button class="chip" style="border-color:#ffd700; color:#ffd700;" @onclick="() => SearchCity(c)">@c</button>
                    }
                </div>
            </div>
        }

        <!-- Loading -->
        @if (loading)
        {
            <p style="text-align:center; color:white; padding:20px;">⏳ Loading...</p>
        }
        else if (errorMessage != null)
        {
            <p style="color:#ff6b6b; text-align:center; padding:12px;">⚠️ @errorMessage</p>
        }
        else if (weather != null)
        {
            @if (GetAlert() != null)
            {
                <div class="alert-box">⚠️ @GetAlert()</div>
            }

            <div class="card" style="text-align:center;">
                <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:8px;">
                    <h2 style="font-size:1.5rem;">@weather.City, @GetCountryName(weather.Sys.Country)</h2>
                    <button @onclick="ToggleFavorite" style="background:none; border:none; font-size:1.5rem; cursor:pointer;">
                        @(favoriteCities.Contains(weather.City) ? "⭐" : "☆")
                    </button>
                </div>

                <p style="color:#ddd; font-size:0.85rem; margin-bottom:8px;">🕐 @GetLocalTime(weather.Timezone)</p>

                <img src="https://openweathermap.org/img/wn/@(weather.Weather[0].Icon)@@2x.png"
                     style="width:90px; animation:spin 10s linear infinite;" />

                <p style="font-size:3.5rem; font-weight:bold;">
                    @(showCelsius ? weather.Main.Temp.ToString("0") + "°C" : ToFahrenheit(weather.Main.Temp).ToString("0") + "°F")
                </p>

                <button class="btn-secondary" style="margin:8px 0 12px 0;" @onclick="ToggleUnit">
                    Switch to @(showCelsius ? "°F" : "°C")
                </button>

                <p style="text-transform:capitalize; color:#90e0ef;">@weather.Weather[0].Description</p>
                <p style="color:#ddd; font-size:0.9rem; margin-top:4px;">
                    Feels like @(showCelsius ? weather.Main.FeelsLike.ToString("0") + "°C" : ToFahrenheit(weather.Main.FeelsLike).ToString("0") + "°F")
                    &nbsp;|&nbsp; Min: @weather.Main.TempMin.ToString("0")° &nbsp;|&nbsp; Max: @weather.Main.TempMax.ToString("0")°
                </p>

                <hr style="border:none; border-top:1px solid rgba(255,255,255,0.2); margin:16px 0;" />

                <div class="stats-grid">
                    <div class="stat-box"><p>💧</p><p style="font-weight:bold;">@weather.Main.Humidity%</p><p style="color:#aaa; font-size:0.75rem;">Humidity</p></div>
                    <div class="stat-box"><p>💨</p><p style="font-weight:bold;">@weather.Wind.Speed m/s</p><p style="color:#aaa; font-size:0.75rem;">Wind</p></div>
                    <div class="stat-box"><p>🔵</p><p style="font-weight:bold;">@weather.Main.Pressure hPa</p><p style="color:#aaa; font-size:0.75rem;">Pressure</p></div>
                    <div class="stat-box"><p>👁️</p><p style="font-weight:bold;">@((weather.Visibility/1000.0).ToString("0.0")) km</p><p style="color:#aaa; font-size:0.75rem;">Visibility</p></div>
                    <div class="stat-box"><p>☀️</p><p style="font-weight:bold; color:@GetUvColor();">@uvIndex.ToString("0.0")</p><p style="color:#aaa; font-size:0.75rem;">UV — @GetUvLabel()</p></div>
                    <div class="stat-box"><p>🌅</p><p style="font-weight:bold;">@UnixToTime(weather.Sys.Sunrise)</p><p style="color:#aaa; font-size:0.75rem;">Sunrise</p></div>
                </div>
            </div>

            @if (forecast != null)
            {
                <h3 style="color:white; margin-bottom:10px;">📅 5-Day Forecast</h3>
                <div class="forecast-grid" style="margin-bottom:20px;">
                    @foreach (var item in GetDailyForecast())
                    {
                        <div class="forecast-box">
                            <p style="font-size:0.75rem; color:#aaa;">@GetDayName(item.DateText)</p>
                            <img src="https://openweathermap.org/img/wn/@(item.Weather[0].Icon).png" style="width:36px;" />
                            <p style="font-weight:bold; font-size:0.9rem;">
                                @(showCelsius ? item.Main.Temp.ToString("0") + "°C" : ToFahrenheit(item.Main.Temp).ToString("0") + "°F")
                            </p>
                        </div>
                    }
                </div>
            }
        }
    </div>
</div>

@code {
    private string city = "";
    private WeatherResponse? weather;
    private ForecastResponse? forecast;
    private string? errorMessage;
    private bool loading = false;
    private bool showCelsius = true;
    private double ToFahrenheit(double c) => (c * 9 / 5) + 32;
    private List<string> recentCities = new();
    private List<string> favoriteCities = new();
    private List<string> suggestions = new();
    private double uvIndex = 0;

    private const string ApiKey = "2b14a2000eeb70bf95441893ed028a5b";

    private static readonly List<string> CityList = new()
    {
        "Accra", "Kumasi", "Tamale", "Takoradi", "Cape Coast",
        "London", "Paris", "New York", "Tokyo", "Dubai",
        "Lagos", "Nairobi", "Cairo", "Johannesburg", "Casablanca",
        "Berlin", "Madrid", "Rome", "Sydney", "Toronto",
        "Singapore", "Bangkok", "Mumbai", "Beijing", "Moscow"
    };

    private void OnSearchInput(ChangeEventArgs e)
    {
        var val = e.Value?.ToString() ?? "";
        city = val;
        if (val.Length >= 2)
            suggestions = CityList
                .Where(c => c.StartsWith(val, StringComparison.OrdinalIgnoreCase))
                .Take(5).ToList();
        else
            suggestions = new();
    }

    private async Task SelectSuggestion(string name)
    {
        city = name;
        suggestions = new();
        await GetWeather();
    }

    private void ToggleUnit() => showCelsius = !showCelsius;

    private void ToggleFavorite()
    {
        if (weather == null) return;
        if (favoriteCities.Contains(weather.City))
            favoriteCities.Remove(weather.City);
        else
            favoriteCities.Add(weather.City);
    }

    private async Task SearchCity(string name)
    {
        city = name;
        await GetWeather();
    }

    private string? GetAlert()
    {
        if (weather == null) return null;
        if (weather.Main.Temp > 40) return "Extreme heat warning! Stay hydrated.";
        if (weather.Main.Temp < 0) return "Freezing temperatures! Wear warm clothing.";
        if (weather.Wind.Speed > 15) return "Strong wind warning! Be careful outdoors.";
        if (weather.Weather[0].Main.ToLower() == "thunderstorm") return "Thunderstorm warning! Stay indoors.";
        if (uvIndex > 8) return $"Very high UV index ({uvIndex:0.0})! Wear sunscreen.";
        return null;
    }

    private string GetLocalTime(int timezone)
    {
        var localTime = DateTime.UtcNow.AddSeconds(timezone);
        return localTime.ToString("hh:mm tt - ddd, MMM dd");
    }

    private string UnixToTime(long unix)
    {
        return DateTimeOffset.FromUnixTimeSeconds(unix).UtcDateTime.ToString("hh:mm tt");
    }

    private string GetUvLabel() => uvIndex switch
    {
        < 3 => "Low", < 6 => "Moderate", < 8 => "High", < 11 => "Very High", _ => "Extreme"
    };

    private string GetUvColor() => uvIndex switch
    {
        < 3 => "#00e400", < 6 => "#ffff00", < 8 => "#ff7e00", < 11 => "#ff0000", _ => "#8f3f97"
    };

    private string GetBackground()
    {
        if (weather == null) return "linear-gradient(135deg,#0f0c29,#302b63,#24243e)";
        return weather.Weather[0].Main.ToLower() switch
        {
            "clear" => "linear-gradient(135deg,#f7971e,#ffd200)",
            "clouds" => "linear-gradient(135deg,#606c88,#3f4c6b)",
            "rain" or "drizzle" => "linear-gradient(135deg,#1c3d5a,#2c5364)",
            "thunderstorm" => "linear-gradient(135deg,#0f0c29,#24243e)",
            "snow" => "linear-gradient(135deg,#e0eafc,#cfdef3)",
            "mist" or "fog" or "haze" => "linear-gradient(135deg,#606c88,#aaa)",
            _ => "linear-gradient(135deg,#0f0c29,#302b63,#24243e)"
        };
    }

    private List<ForecastItem> GetDailyForecast()
    {
        if (forecast == null) return new();
        return forecast.List.Where(f => f.DateText.Contains("12:00:00")).Take(5).ToList();
    }

    private string GetDayName(string dateText)
    {
        if (DateTime.TryParse(dateText, out var dt)) return dt.ToString("ddd");
        return dateText;
    }

    private string GetCountryName(string code) => code switch
    {
        "GH" => "Ghana", "US" => "United States", "GB" => "United Kingdom",
        "NG" => "Nigeria", "ZA" => "South Africa", "KE" => "Kenya",
        "FR" => "France", "DE" => "Germany", "JP" => "Japan",
        "CN" => "China", "IN" => "India", "BR" => "Brazil",
        "CA" => "Canada", "AU" => "Australia", "IT" => "Italy",
        "ES" => "Spain", "MX" => "Mexico", "RU" => "Russia",
        "EG" => "Egypt", "CM" => "Cameroon", "SN" => "Senegal",
        "SG" => "Singapore", "KR" => "South Korea", "SA" => "Saudi Arabia",
        "AE" => "UAE", "TH" => "Thailand", "NZ" => "New Zealand",
        "AR" => "Argentina", "PT" => "Portugal", "NL" => "Netherlands",
        "SE" => "Sweden", "NO" => "Norway", "TR" => "Turkey",
        _ => code
    };

    private async Task GetLocationWeather()
    {
        try
        {
            loading = true;
            errorMessage = null;
            var location = await JS.InvokeAsync<LocationResult>("getLocation");
            var url = $"https://api.openweathermap.org/data/2.5/weather?lat={location.Lat}&lon={location.Lon}&units=metric&appid={ApiKey}";
            weather = await Http.GetFromJsonAsync<WeatherResponse>(url);
            city = weather?.City ?? "";
            var forecastUrl = $"https://api.openweathermap.org/data/2.5/forecast?lat={location.Lat}&lon={location.Lon}&units=metric&appid={ApiKey}";
            forecast = await Http.GetFromJsonAsync<ForecastResponse>(forecastUrl);
        }
        catch
        {
            errorMessage = "Could not get your location.";
        }
        finally
        {
            loading = false;
        }
    }

    private async Task GetWeather()
    {
        if (string.IsNullOrWhiteSpace(city)) return;
        loading = true;
        errorMessage = null;
        weather = null;
        forecast = null;
        uvIndex = 0;
        suggestions = new();

        try
        {
            var url = $"https://api.openweathermap.org/data/2.5/weather?q={city}&units=metric&appid={ApiKey}";
            weather = await Http.GetFromJsonAsync<WeatherResponse>(url);

            if (weather != null)
            {
                var forecastUrl = $"https://api.openweathermap.org/data/2.5/forecast?q={city}&units=metric&appid={ApiKey}";
                forecast = await Http.GetFromJsonAsync<ForecastResponse>(forecastUrl);
            }

            if (!recentCities.Contains(city))
            {
                recentCities.Insert(0, city);
                if (recentCities.Count > 5) recentCities.RemoveAt(5);
            }
        }
        catch
        {
            errorMessage = "City not found. Please check spelling.";
        }
        finally
        {
            loading = false;
        }
    }

    public class LocationResult
    {
        public double Lat { get; set; }
        public double Lon { get; set; }
    }
}