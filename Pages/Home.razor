@page "/"
@using System.Net.Http.Json
@using WeatherApp.Models
@inject HttpClient Http

<PageTitle>Weather App</PageTitle>

<div style="min-height:100vh; background:@GetBackground(); font-family:Segoe UI,sans-serif; padding:40px 20px; transition: background 1s;">
    <div style="max-width:560px; margin:0 auto;">

        <h1 style="text-align:center; color:white; font-size:2.2rem; margin-bottom:4px;">🌍 Weather App</h1>
        <p style="text-align:center; color:#ddd; margin-bottom:28px;">Live weather for any city</p>

        <!-- Search Bar -->
        <div style="display:flex; gap:8px; margin-bottom:16px;">
            <input @bind="city" @bind:event="oninput"
                   placeholder="Enter city name..."
                   style="flex:1; padding:14px 18px; border-radius:12px; border:none; font-size:1rem; background:#ffffff20; color:white; outline:none;" />
            <button @onclick="GetWeather"
                    style="padding:14px 20px; background:#00b4d8; color:white; border:none; border-radius:12px; font-size:1rem; cursor:pointer; font-weight:bold;">
                Search
            </button>
        </div>

        <!-- Recent Searches -->
        @if (recentCities.Count > 0)
        {
            <div style="margin-bottom:20px;">
                <p style="color:#ddd; font-size:0.85rem; margin-bottom:8px;">Recent searches:</p>
                <div style="display:flex; flex-wrap:wrap; gap:8px;">
                    @foreach (var c in recentCities)
                    {
                        <button @onclick="() => SearchCity(c)"
                                style="padding:6px 14px; background:#ffffff15; color:white; border:1px solid #ffffff30; border-radius:20px; cursor:pointer; font-size:0.85rem;">
                            @c
                        </button>
                    }
                </div>
            </div>
        }

        <!-- Loading -->
        @if (loading)
        {
            <p style="text-align:center; color:white;">⏳ Loading...</p>
        }
        else if (errorMessage != null)
        {
            <p style="color:#ff6b6b; text-align:center;">⚠️ @errorMessage</p>
        }
        else if (weather != null)
        {
            <!-- Current Weather Card -->
            <div style="background:#ffffff10; border-radius:24px; padding:32px; color:white; text-align:center; margin-bottom:20px;">

                <h2 style="margin:0 0 4px 0;">@weather.City, @weather.Sys.Country</h2>

                <img src="https://openweathermap.org/img/wn/@(weather.Weather[0].Icon)@@2x.png" style="width:100px;" />

                <p style="font-size:4rem; font-weight:bold; margin:0;">
                    @(showCelsius ? weather.Main.Temp.ToString("0") + "°C" : ToFahrenheit(weather.Main.Temp).ToString("0") + "°F")
                </p>

                <button @onclick="ToggleUnit"
                        style="margin:8px 0 12px 0; padding:6px 20px; background:#00b4d8; color:white; border:none; border-radius:20px; cursor:pointer; font-size:0.9rem;">
                    Switch to @(showCelsius ? "°F" : "°C")
                </button>

                <p style="text-transform:capitalize; color:#90e0ef; margin:4px 0;">@weather.Weather[0].Description</p>
                <p style="color:#ddd; font-size:0.9rem;">
                    Feels like @(showCelsius ? weather.Main.FeelsLike.ToString("0") + "°C" : ToFahrenheit(weather.Main.FeelsLike).ToString("0") + "°F")
                </p>

                <div style="display:flex; justify-content:space-around; margin-top:16px;">
                    <div><p>💧</p><p style="font-weight:bold;">@weather.Main.Humidity%</p><p style="color:#aaa; font-size:0.85rem;">Humidity</p></div>
                    <div><p>💨</p><p style="font-weight:bold;">@weather.Wind.Speed m/s</p><p style="color:#aaa; font-size:0.85rem;">Wind</p></div>
                </div>
            </div>

            <!-- 5-Day Forecast -->
            @if (forecast != null)
            {
                <h3 style="color:white; margin-bottom:12px;">📅 5-Day Forecast</h3>
                <div style="display:grid; grid-template-columns:repeat(5,1fr); gap:8px;">
                    @foreach (var item in GetDailyForecast())
                    {
                        <div style="background:#ffffff10; border-radius:16px; padding:12px; color:white; text-align:center;">
                            <p style="margin:0; font-size:0.8rem; color:#aaa;">@GetDayName(item.DateText)</p>
                            <img src="https://openweathermap.org/img/wn/@(item.Weather[0].Icon).png" style="width:40px;" />
                            <p style="margin:0; font-weight:bold; font-size:0.95rem;">
                                @(showCelsius ? item.Main.Temp.ToString("0") + "°C" : ToFahrenheit(item.Main.Temp).ToString("0") + "°F")
                            </p>
                        </div>
                    }
                </div>
            }
        }
    </div>
</div>

@code {
    private string city = "";
    private WeatherResponse? weather;
    private ForecastResponse? forecast;
    private string? errorMessage;
    private bool loading = false;
    private bool showCelsius = true;
    private List<string> recentCities = new();

    private const string ApiKey = "2b14a2000eeb70bf95441893ed028a5b";

    private void ToggleUnit() => showCelsius = !showCelsius;
    private double ToFahrenheit(double c) => (c * 9 / 5) + 32;

    private async Task SearchCity(string name)
    {
        city = name;
        await GetWeather();
    }

    private string GetBackground()
    {
        if (weather == null) return "linear-gradient(135deg,#0f0c29,#302b63,#24243e)";
        var condition = weather.Weather[0].Main.ToLower();
        return condition switch
        {
            "clear" => "linear-gradient(135deg,#f7971e,#ffd200)",
            "clouds" => "linear-gradient(135deg,#606c88,#3f4c6b)",
            "rain" => "linear-gradient(135deg,#1c3d5a,#2c5364)",
            "drizzle" => "linear-gradient(135deg,#1c3d5a,#2c5364)",
            "thunderstorm" => "linear-gradient(135deg,#0f0c29,#24243e)",
            "snow" => "linear-gradient(135deg,#e0eafc,#cfdef3)",
            "mist" or "fog" or "haze" => "linear-gradient(135deg,#606c88,#aaa)",
            _ => "linear-gradient(135deg,#0f0c29,#302b63,#24243e)"
        };
    }

    private List<ForecastItem> GetDailyForecast()
    {
        if (forecast == null) return new();
        return forecast.List
            .Where(f => f.DateText.Contains("12:00:00"))
            .Take(5)
            .ToList();
    }

    private string GetDayName(string dateText)
    {
        if (DateTime.TryParse(dateText, out var dt))
            return dt.ToString("ddd");
        return dateText;
    }

    private async Task GetWeather()
    {
        if (string.IsNullOrWhiteSpace(city)) return;
        loading = true;
        errorMessage = null;
        weather = null;
        forecast = null;

        try
        {
            var url = $"https://api.openweathermap.org/data/2.5/weather?q={city}&units=metric&appid={ApiKey}";
            weather = await Http.GetFromJsonAsync<WeatherResponse>(url);

            var forecastUrl = $"https://api.openweathermap.org/data/2.5/forecast?q={city}&units=metric&appid={ApiKey}";
            forecast = await Http.GetFromJsonAsync<ForecastResponse>(forecastUrl);

            if (!recentCities.Contains(city))
            {
                recentCities.Insert(0, city);
                if (recentCities.Count > 5) recentCities.RemoveAt(5);
            }
        }
        catch
        {
            errorMessage = "City not found. Please check spelling.";
        }
        finally
        {
            loading = false;
        }
    }
}